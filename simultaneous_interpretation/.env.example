# VoiceTranslate Pro 環境変数テンプレート
# このファイルを .env にコピーして使用してください
# cp .env.example .env
# ⚠️ このファイル (.env) は絶対に Git にコミットしないでください

# ============================================
# OpenAI API Key（必須）
# ============================================
# 優先順位: OPENAI_API_KEY > OPENAI_REALTIME_API_KEY > VOICETRANSLATE_API_KEY
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_REALTIME_API_KEY=your-realtime-api-key-here
# VOICETRANSLATE_API_KEY=your-voicetranslate-api-key-here

# ============================================
# OpenAI Models Configuration（モデル設定）
# ============================================
# 専用同時通訳セッション（/v1/realtime/translations）。既定: gpt-realtime-translate
# ※ 標準 voice-agent を使う場合は gpt-realtime-2 等に変更し、URL も /v1/realtime にする
OPENAI_REALTIME_MODEL=gpt-realtime-translate

# 音声認識モデル（オプション。既定: gpt-realtime-whisper）
# OPENAI_TRANSCRIBE_MODEL=gpt-realtime-whisper

# Chat Completions（言語検出・テキスト翻訳）
OPENAI_CHAT_MODEL=gpt-5.6

# Realtime 接続 URL（翻訳EPとモデルを揃えること）
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime/translations

# ============================================
# データベース設定
# ============================================
# 空なら OS 既定パス（AppData 等）を使用
CONVERSATION_DB_PATH=

# ============================================
# アプリケーション設定
# ============================================
NODE_ENV=development

# ============================================
# 決済（ForgePay）— サーバ側 api/*.js が使用
# ============================================
FORGEPAY_API_URL=http://localhost:3000
FORGEPAY_API_KEY=fpb_test_xxxxxxxxxxxx
FORGEPAY_SUBSCRIPTION_PRODUCT_ID=
FORGEPAY_ONETIME_PRODUCT_ID=
FORGEPAY_ONETIME_AMOUNT=980
FORGEPAY_CURRENCY=jpy
APP_PUBLIC_URL=https://your-app.example.com
FORGEPAY_CALLBACK_SECRET=
FORGEPAY_DEV_BYPASS_SECRET=
