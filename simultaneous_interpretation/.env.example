# VoiceTranslate Pro 環境変数テンプレート
# このファイルを .env にコピーして使用してください
# cp .env.example .env

# ============================================
# OpenAI API Key（必須）
# ============================================
# 取得方法: https://platform.openai.com/api-keys
# 形式: sk-proj-... または sk-...
# 優先順位: OPENAI_REALTIME_API_KEY > VOICETRANSLATE_API_KEY > OPENAI_API_KEY
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_REALTIME_API_KEY=your-realtime-api-key-here
# VOICETRANSLATE_API_KEY=your-voicetranslate-api-key-here

# ============================================
# OpenAI Models Configuration（モデル設定）
# ============================================
# 2種類のモデルを用途別に設定

# 1-1. Realtime APIモデル（音声→音声翻訳、音声認識）
# 用途:
#   - 音声→音声翻訳（メイン機能）
#   - 音声認識（自動：whisper-1）
#   - 言語自動検出
# デフォルト: gpt-realtime-2025-08-28 (最新・推奨)
# 利用可能: gpt-realtime-2025-08-28, gpt-4o-realtime-preview-2024-12-17
# 新機能: Cedar/Marin音声、画像入力、MCP対応、SIP対応
OPENAI_REALTIME_MODEL=gpt-realtime-2025-08-28

# 1-2. 音声認識モデル（オプション）
# 用途:
#   - 音声認識（オーディオ入力時のみ）
#   - 自動言語検出
# デフォルト: whisper-1
# 利用可能: whisper-1, gpt-4o-transcribe-diarize
# whisper-1: 音声認識のみ、gpt-4o-transcribe-diarize: 音声認識 + 話者分離
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize

# 2. Chat Completions APIモデル（言語検出、テキスト翻訳）
# 用途:
#   - 言語検出（テキスト → 言語コード）
#   - テキスト翻訳（テキスト → テキスト）
# デフォルト: gpt-4o
# 推奨: gpt-4o, gpt-5-2025-08-07

OPENAI_CHAT_MODEL=gpt-5-2025-08-07

# OpenAI Realtime API URL
# デフォルト: wss://api.openai.com/v1/realtime
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime

# ============================================
# Azure Speech Services（オプション）
# ============================================
# 取得方法: https://portal.azure.com/
# Speech Services リソースを作成後、「キーとエンドポイント」から取得
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=japaneast

# ============================================
# Google Cloud Translation API（オプション）
# ============================================
# 取得方法: https://console.cloud.google.com/
# Cloud Translation API を有効化後、認証情報から API Key を作成
GOOGLE_TRANSLATION_API_KEY=your-google-api-key-here

# ============================================
# データベース設定
# ============================================
# 会話データベースファイルパス（オプション）
#
# 空の場合: デフォルトパスを使用
#   - Windows: C:\Users\{ユーザー}\AppData\Roaming\simultaneous-interpretation\conversations.db
#   - macOS:   ~/Library/Application Support/simultaneous-interpretation/conversations.db
#   - Linux:   ~/.config/simultaneous-interpretation/conversations.db
#
# カスタムパスを指定する場合:
#   - Windows: C:\path\to\conversations.db
#   - macOS/Linux: /path/to/conversations.db
#
# 例:
#   CONVERSATION_DB_PATH=D:\data\conversations.db
#   CONVERSATION_DB_PATH=/mnt/data/conversations.db
#
CONVERSATION_DB_PATH=

# ============================================
# アプリケーション設定
# ============================================
# 環境: development, production, test
NODE_ENV=development

# ログレベル: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ============================================
# 開発者向け設定（オプション）
# ============================================
# デバッグモード: true, false
DEBUG_MODE=true

# テストモード: true, false
TEST_MODE=false

# ============================================
# 決済（ForgePay 共通決済サービス）— サーバ側 api/*.js が使用
# ============================================
# 決済は ForgePay 経由。アプリ側に Stripe Secret / Webhook Secret / Price ID は持たない。
# これらは Vercel サーバレス関数（api/create-checkout-session, check-subscription,
# forgepay-callback）でのみ使用され、クライアント（拡張/Electron）には渡らない。
#
# ForgePay のベース URL（ローカル: http://localhost:3000、本番: https://<your-forgepay>）
FORGEPAY_API_URL=http://localhost:3000
# ForgePay 開発者 API キー（fpb_test_... / 本番は fpb_live_...）
# 取得方法: ForgePay ダッシュボード(http://localhost:3001)の「開発者登録」
#           もしくは scripts/forgepay-provision.mjs を実行
FORGEPAY_API_KEY=fpb_test_xxxxxxxxxxxx

# サブスクリプション（月額）の ForgePay 商品 ID（UUID）
FORGEPAY_SUBSCRIPTION_PRODUCT_ID=
# 一回払い（買い切り）の ForgePay 商品 ID（UUID）。未設定時は下記アドホック金額を使用
FORGEPAY_ONETIME_PRODUCT_ID=
# 一回払いのアドホック金額（最小通貨単位。例: 円なら 980 = 980円）
FORGEPAY_ONETIME_AMOUNT=980
# アドホック決済の通貨コード（既定 jpy）
FORGEPAY_CURRENCY=jpy

# 決済成功/キャンセルの遷移先ベース URL（https 必須。省略時は ForgePay ダッシュボード設定）
APP_PUBLIC_URL=https://your-app.example.com

# コールバック検証用の共有シークレット（任意・多層防御）。設定すると
# ForgePay からの通知に X-Forgepay-Secret ヘッダーを要求する。
FORGEPAY_CALLBACK_SECRET=

# ============================================
# セキュリティ注意事項
# ============================================
# ⚠️ このファイル (.env) は絶対に Git にコミットしないでください
# ⚠️ API Key は他人と共有しないでください
# ⚠️ API Key が漏洩した場合は直ちに無効化してください

