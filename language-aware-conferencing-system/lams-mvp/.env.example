# ===========================================
# LAMS 環境変数設定
# ===========================================

# -------------------------------------------
# データベース設定
# -------------------------------------------
DB_PASSWORD=lams_secret_2024
DB_HOST=host.docker.internal
DB_PORT=5433
DATABASE_URL=postgresql://lams:lams_secret_2024@host.docker.internal:5433/lams

# -------------------------------------------
# Redis設定
# -------------------------------------------
REDIS_PORT=6380
REDIS_URL=redis://host.docker.internal:6380/0

# -------------------------------------------
# JWT認証設定
# -------------------------------------------
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===========================================
# AIプロバイダー設定
# ===========================================
# プロバイダー選択:
#   - gpt4o_transcribe: GPT-4o-transcribe ASR (300-500ms) + 翻訳 + TTS
#   - gpt_realtime: GPT-Realtime S2S (200-400ms, 音声直接翻訳)
#   - deepgram: Deepgram Nova-3 ASR (<300ms) + 翻訳 + TTS
#   - google: Mode B（Chirp 3 ASR + Cloud Translation）。認証/ライブラリ未整備時は
#             起動エラーにせず gpt4o_transcribe へ自動フォールバック
AI_PROVIDER=gpt_realtime

# -------------------------------------------
# Lite 本地スタック（P1：faster-whisper / OPUS-MT / Kokoro / Silero VAD）
# -------------------------------------------
# ステージ別スロット。"local" 指定でその段のみ本地モデルを使う（Composite 有効化）。
# ランタイム未導入時は自動で雲へフォールバック（構築時）。既定 auto は現状維持。
#   ASR_PROVIDER: auto / gpt4o / deepgram / google / local
#   MT_PROVIDER : auto / openai / google / local
#   TTS_PROVIDER: auto / openai / none / local
# ASR_PROVIDER=auto
# MT_PROVIDER=auto
# TTS_PROVIDER=auto
# VAD バックエンド: energy（既定）/ silero（要 torch。未導入時 energy へ縮退）
# VAD_BACKEND=energy
# VRAM 予算（MB）。VRAM Broker がこの範囲でモデル常駐を調停（12GB の目安）
# VRAM_BUDGET_MB=11000
# 本地 ASR（faster-whisper / CTranslate2）
# LOCAL_ASR_MODEL=large-v3-turbo
# LOCAL_ASR_DEVICE=cuda
# LOCAL_ASR_COMPUTE_TYPE=int8
# 本地 MT（OPUS-MT / Marian + CTranslate2）。model_dir 未設定なら local MT 無効
# LOCAL_MT_MODEL_DIR=
# LOCAL_MT_DEVICE=cpu
# LOCAL_MT_COMPUTE_TYPE=int8
# 本地 TTS（Kokoro-82M）。Lite の訳音は任意（字幕優先）
# LOCAL_TTS_MODEL=kokoro-82m
# LOCAL_TTS_VOICE=af_heart
# LOCAL_TTS_DEVICE=cpu

# ストリーミング字幕（P2：partial/final 事件協議）。ASR 原文の暫定字幕で首字遅延短縮。
# 既定 False（final のみ）。有効化は本地/低遅延 ASR 環境向け。
# ENABLE_PARTIAL_SUBTITLES=false
# PARTIAL_MS=700

# -------------------------------------------
# 離線高質量重跑・音声アーカイブ（P3-D：改善案 §5.3）
# -------------------------------------------
# 音声の暗号化アーカイブ（既定 OFF：プライバシー既定オフ）。有効時のみ発話音声を
# AES-GCM で暗号化保存し、DB には audio_hash 参照のみ持つ。会議の同意ポリシー準拠。
# ENABLE_AUDIO_ARCHIVE=false
# AUDIO_ARCHIVE_DIR=/data/audio_archive
# AES-GCM 鍵（base64 で 32 バイト）。未設定なら暗号化不可でアーカイブは無効化される。
# AUDIO_ARCHIVE_KEY=
# アーカイブ保持日数（超過分は purge 対象。0 以下で無期限）
# AUDIO_RETENTION_DAYS=30
# 中間パイプライン事件（回放ログ）を記録（既定 true。離線重跑の前提）
# ENABLE_PIPELINE_EVENT_LOG=true

# -------------------------------------------
# 話者分離 diarization（P4-A：改善案 §4）
# -------------------------------------------
# 声紋 embedding による話者識別/クラスタリング（既定 OFF）。有効時のみ発話音声から
# embedding を抽出し consent 済み登録話者と照合、未登録は "Speaker N" を付与する。
# speaker_id（LiveKit track 由来）は不変で speaker_label は増強情報。
# ENABLE_DIARIZATION=false
# 声紋バックエンド: none（無効）/ resemblyzer。resemblyzer 未導入なら自動無効化。
# SPEAKER_EMBED_BACKEND=none
# 登録話者一致とみなす余弦類似度閾値
# SPEAKER_MATCH_THRESHOLD=0.75
# 会議内クラスタリングで同一話者とみなす余弦類似度閾値
# SPEAKER_CLUSTER_THRESHOLD=0.70

# -------------------------------------------
# A/B テスト配信（P4-C：改善案 §5.1）
# -------------------------------------------
# モデル候補の A/B 実験配信（既定 OFF）。同一 unit は常に同じ variant へ決定的配信。
# ENABLE_AB_TESTING=false
# 実験定義の JSON 配列。要素={"key","stage","unit","enabled","variants":[...]}
# variant={"name","model_id","weight"}。JSON 不正・個別不正は fail-safe でスキップ。
# EXPERIMENTS_CONFIG=[{"key":"asr_ab","stage":"asr","unit":"session","enabled":true,"variants":[{"name":"control","model_id":"asr-openai-transcribe","weight":50},{"name":"treatment","model_id":"asr-faster-whisper","weight":50}]}]

# -------------------------------------------
# プロバイダー・プラグイン SDK（P4-D：改善案 §5.1）
# -------------------------------------------
# 外部 ASR/MT/TTS プラグインの読み込み（既定 OFF＝信頼境界）。各モジュールは
# register(registry) 関数または PLUGINS(list) を公開する。import 失敗・不正定義は
# fail-safe で当該のみスキップし、コアを壊さない。
# ENABLE_PROVIDER_PLUGINS=false
# PROVIDER_PLUGINS=myorg.lams_plugins.whisperx, myorg.lams_plugins.elevenlabs

# -------------------------------------------
# モデル治理カタログのランタイム選択（P4-wiring：改善案 §5.1）
# -------------------------------------------
# 有効時、各ステージの "auto" スロットを model_registry の production カードで解決する
# （治理カタログの production 昇格が実行時プロバイダー選択へ反映される）。既定 OFF＝挙動不変。
# USE_MODEL_REGISTRY_SELECTION=false

# -------------------------------------------
# OpenAI API 設定【gpt4o_transcribe, gpt_realtime共通】
# -------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=

# GPT-4o-transcribe 設定（ASR用）
# 利用可能: gpt-4o-transcribe, gpt-4o-mini-transcribe, whisper-1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# OPENAI_DETECT_MODEL=whisper-1   # 言語自動検出用（verbose_json 対応モデルのみ）

# GPT-Realtime S2S 設定（音声直接翻訳用、WebSocket API）
# 利用可能: gpt-realtime-1.5（推奨）, gpt-realtime, gpt-realtime-mini
# gpt-realtime-1.5: 命令追従+7%, 英数字精度+10%, 多言語対応向上
OPENAI_REALTIME_MODEL=gpt-realtime-1.5

# テキスト翻訳用モデル
# 利用可能: gpt-4o-mini, gpt-4o, gpt-4-turbo
OPENAI_TRANSLATE_MODEL=gpt-4o-mini

# 議事録・要約生成用モデル（Phase 1-T5。長文要約のため翻訳と分離）
OPENAI_MINUTES_MODEL=gpt-4o-mini

# TTS設定
# モデル: tts-1, tts-1-hd
# 音声: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# -------------------------------------------
# 言語検出設定
# -------------------------------------------
# 言語検出モード:
#   - auto: 自動検出（Whisper/GPT-4oで言語を検出、精度高）
#   - hint: 話者のnative_languageをヒントとして使用（検出なし、低遅延）
LANGUAGE_DETECTION_MODE=auto

# -------------------------------------------
# Deepgram API 設定【deepgramプロバイダー用】
# -------------------------------------------
DEEPGRAM_API_KEY=
DEEPGRAM_BASE_URL=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi

# -------------------------------------------
# Gemini API 設定【将来の拡張用、現在未使用】
# -------------------------------------------
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_TEXT_MODEL=models/gemini-2.5-flash

# -------------------------------------------
# LLM 補正設定【改善.md 11章 / Mode B・fallback 用】
# 翻訳結果の校正（表記統一・文脈補正・数字保持）に使う LLM。
#   off    : 補正なし（既定。既存翻訳フローへ非介入）
#   gemini : Gemini で校正（要 GEMINI_API_KEY。未設定時は自動無効化）
# -------------------------------------------
LLM_CORRECTION_PROVIDER=off

# -------------------------------------------
# 議事録・要約生成 LLM 選択【Phase 1-T5 / 会後議事録】
#   auto   : GPT 優先、鍵が無ければ Gemini へ fallback（既定）
#   gpt    : GPT 固定（要 OPENAI_API_KEY）
#   gemini : Gemini 固定（要 GEMINI_API_KEY）
#   off    : 議事録生成を無効化（API は 503 を返す）
# -------------------------------------------
LLM_MINUTES_PROVIDER=auto

# -------------------------------------------
# Google Cloud 設定【改善.md Mode B：Chirp 3 ASR + Cloud Translation】
# 認証は GOOGLE_APPLICATION_CREDENTIALS（サービスアカウント JSON パス）or ADC。
# GOOGLE_PROJECT_ID 未設定時は google プロバイダーは無効扱い（fallback）。
# -------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PROJECT_ID=
GOOGLE_SPEECH_LOCATION=us-central1
GOOGLE_SPEECH_MODEL=chirp_3
GOOGLE_TRANSLATE_LOCATION=global
GOOGLE_GLOSSARY_ID=

# -------------------------------------------
# LiveKit / WebRTC 設定（WebRTC 接続に必須）
# dev 既定値は docker-compose.yml の livekit コンテナと一致済み。本番では必ず変更する。
# 注意: LIVEKIT_URL はここに書かないこと（Docker では ws://livekit:7880、
#       ローカルでは ws://localhost:7880 が自動選択される。.env に書くと Docker 側が壊れる）
# -------------------------------------------
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_in_production

# -------------------------------------------
# QoS設定
# -------------------------------------------
MAX_LATENCY_MS=1200
MAX_JITTER_MS=200

# -------------------------------------------
# ポート・ネットワーク設定（ここだけ変更すれば全体に反映される唯一の設定箇所）
# -------------------------------------------
# WSL/Linux のホストIPアドレス。LAN公開時は ./scripts/set-host-ip.sh が自動検出して書き換える
HOST_IP=127.0.0.1
# バックエンドのホスト側ポート（Docker外部マッピング用・ローカル開発用）
# この値だけ変えれば docker-compose.yml・CORS設定・nginx が全て追随する
BACKEND_PORT=8090
# フロントエンドのホスト側ポート（Docker外部マッピング用）
FRONTEND_PORT=5273
# CORS許可オリジン追加分（省略可。HOST_IP+FRONTEND_PORT は自動生成）
# 追加オリジンが必要な場合のみ設定例: CORS_ORIGINS=http://example.com

# -------------------------------------------
# 環境設定
# -------------------------------------------
ENV=development

# -------------------------------------------
# 対応言語（カンマ区切り）
# -------------------------------------------
SUPPORTED_LANGUAGES=ja,en,zh,vi
