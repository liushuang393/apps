# ===========================================
# LAMS フロントエンド 環境変数設定（ローカル開発用）
# ===========================================
# ※ Docker起動時は docker-compose.yml が .env（ルート）から自動注入するため
#    このファイルは不要。ローカル開発（npm run dev）時にのみ使用する。

# -------------------------------------------
# 開発サーバー設定
# -------------------------------------------
# 開発サーバーのポート番号（ルート .env の FRONTEND_PORT に合わせて設定）
VITE_PORT=5273

# -------------------------------------------
# バックエンドAPI設定
# -------------------------------------------
# ローカル開発用バックエンドポート（Viteプロキシ転送先。ルート .env の BACKEND_PORT に合わせる）
# VITE_API_URL が空のときのみ使用される
VITE_BACKEND_PORT=8090

# REST API のURL（空にするとViteプロキシ経由でlocalhost:VITE_BACKEND_PORTに転送）
# 直接指定する場合: VITE_API_URL=http://localhost:8090
VITE_API_URL=

# WebSocket のURL（空にすると自動検出）
# 直接指定する場合: VITE_WS_URL=ws://localhost:8090
VITE_WS_URL=

